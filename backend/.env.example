# Local dev port (fixed — do not change unless you update frontend/.env.development too)
PORT=3001

# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Email OTP (waitlist / admin login)
RESEND_API_KEY=re_your_resend_key
EMAIL_FROM=Pirttrip <noreply@yourdomain.com>
OTP_SECRET=use_a_long_random_string_at_least_32_characters

# Partner registration SMS OTP (AquaSMS GET API)
AQUASMS_API_KEY=your_aquasms_api_key
AQUASMS_USERNAME=pirttrip
AQUASMS_SENDER_NAME=MARSTP
AQUASMS_SMSTYPE=TRANS
AQUASMS_BASE_URL=http://login.aquasms.com/sendSMS
# Set OTP_DEBUG=true locally to log full OTP codes in server logs (never in production)
# OTP_DEBUG=true

# Migrations: npm run db:migrate
SUPABASE_DB_PASSWORD=your_database_password

# Railway sets PORT automatically — do not hardcode in production
# HOST=0.0.0.0
