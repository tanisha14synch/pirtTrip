# Loaded automatically by `npm run dev` (Nuxt development mode)
# Copy to: frontend/.env.development

# Fixed local dev ports — always use these (no random ports)
PORT=3000
FRONTEND_PORT=3000
BACKEND_PORT=3001

API_URL=http://127.0.0.1:3001

# Optional: handle waitlist on Nuxt instead of proxy (usually use backend/.env only)
# SUPABASE_URL=https://YOUR_REF.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=...

# Partner page on subdomain (same port as frontend)
NUXT_PUBLIC_PARTNER_SITE_URL=http://business.localhost:3000
NUXT_PUBLIC_MAIN_SITE_URL=http://localhost:3000
