# Used for local production preview (`npm run build && npm run start`)
# On Railway: set these in the frontend service Variables UI (not in git)

API_URL=https://api.pirttrip.com

# Do NOT set NUXT_PUBLIC_API_URL unless you want browser to call API host directly.
# NUXT_PUBLIC_API_DIRECT=true

# Main marketing service (www / app domain):
# NUXT_PUBLIC_PARTNER_SITE_URL=https://business.pirttrip.com

# Partner subdomain on same service (custom domain business.pirttrip.com):
# NUXT_PUBLIC_PARTNER_HOSTS=business.pirttrip.com

# Or dedicated partner-only deploy (root / = partner page):
# NUXT_PUBLIC_SITE_VARIANT=business
