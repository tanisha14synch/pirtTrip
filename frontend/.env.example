# ─── Public (embedded in client bundle at build time) ───
NUXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Backend API URL (Railway backend service public URL, no trailing slash)
# Local dev: leave empty to use Nuxt proxy /api → http://127.0.0.1:3001
NUXT_PUBLIC_API_URL=https://your-backend.up.railway.app

# Aliases (optional)
# API_URL=https://your-backend.up.railway.app
# NUXT_PUBLIC_API_BASE_URL=https://your-backend.up.railway.app

# ─── Server (Nuxt SSR only, optional) ───
# HOST=0.0.0.0
# PORT=3000
