# ─── Public (embedded in client bundle at build time) ───
NUXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Production (recommended): leave NUXT_PUBLIC_API_URL empty in Railway build.
# Browser calls same-origin /api; server proxies to API_URL at runtime.
API_URL=https://api.pirttrip.com

# Optional: only if you want the browser to call the API host directly (needs CORS).
# NUXT_PUBLIC_API_URL=https://api.pirttrip.com
# NUXT_PUBLIC_API_DIRECT=true

# Local dev: leave both empty — Nuxt proxies /api → http://127.0.0.1:3001
# NUXT_PUBLIC_API_BASE_URL=http://localhost:3001

# ─── Server (Nuxt SSR only, optional) ───
# HOST=0.0.0.0
# PORT=3000
