# ─── Shared (copy to frontend/.env) ───
NUXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Server-only (waitlist / partner API on Nuxt host) — copy to Railway frontend Variables
# SUPABASE_URL= same as NUXT_PUBLIC_SUPABASE_URL
# SUPABASE_SERVICE_ROLE_KEY= from Supabase Dashboard → Settings → API → service_role

# ─── Local only (copy to frontend/.env.development) ───
# See .env.development.example → API_URL=http://127.0.0.1:3001

# ─── Production only (Railway frontend service Variables) ───
# See .env.production.example → API_URL=https://api.pirttrip.com
# Do NOT set NUXT_PUBLIC_API_URL unless using NUXT_PUBLIC_API_DIRECT=true

# Partner subdomain (same frontend app — no extra folder)
# Option A: attach business.pirttrip.com to the same Railway frontend service (host detection)
# NUXT_PUBLIC_PARTNER_HOSTS=business.pirttrip.com,business.localhost
#
# Option B: second Railway frontend service only for the partner subdomain
# NUXT_PUBLIC_SITE_VARIANT=business
#
# Main site: send /business to the partner subdomain
# NUXT_PUBLIC_PARTNER_SITE_URL=https://business.pirttrip.com

# Partner site logo + copyright link back to marketing home
# NUXT_PUBLIC_MAIN_SITE_URL=https://pirttrip.com

# Full guide: docs/ENV.md
