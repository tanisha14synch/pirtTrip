# Public (exposed to browser)
NUXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Backend API (optional in dev — Nuxt proxies /api to :3001)
# NUXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Server secrets live in backend/.env — see backend/.env.example

# Optional: MSG91 (if not using Supabase Phone Auth)
# MSG91_AUTH_KEY=
# MSG91_TEMPLATE_ID=
# MSG91_SENDER_ID=
