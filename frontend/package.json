{
  "name": "pirt-trip-frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "bash -lc 'lsof -ti:3000,3001 | xargs kill -9 2>/dev/null || true; concurrently -k -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"'",
    "dev:frontend": "nuxt dev --port 3000",
    "dev:backend": "CHOKIDAR_USEPOLLING=1 CHOKIDAR_INTERVAL=300 npm run dev --prefix ../backend",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "start": "node .output/server/index.mjs",
    "postinstall": "nuxt prepare"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@pinia/nuxt": "^0.11.3",
    "@supabase/supabase-js": "^2.106.2",
    "nuxt": "^3.16.2",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "typescript": "^5.8.3"
  }
}
