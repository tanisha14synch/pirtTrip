# Local dev (business app on :3002, API on :3001)
# npm run dev -- --port 3002

# Server-side proxy to Nitro API (required in production on Railway)
API_URL=http://127.0.0.1:3001

# Optional: call API host directly from the browser
# NUXT_PUBLIC_API_DIRECT=true
# NUXT_PUBLIC_API_URL=https://your-api.up.railway.app

# Main marketing site (footer legal links, logo)
NUXT_PUBLIC_MAIN_SITE_URL=https://www.pirttrip.com
