{
  "name": "pirt-trip",
  "private": true,
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:admin": "npm run dev --prefix admin",
    "dev:all": "concurrently -n backend,frontend,admin -c blue,green,magenta \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:admin\"",
    "build": "npm run build:backend && npm run build:frontend && npm run build:admin",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build:admin": "npm run build --prefix admin",
    "start:backend": "npm run start --prefix backend",
    "start:frontend": "npm run start --prefix frontend",
    "start:admin": "npm run start --prefix admin",
    "db:migrate": "npm run db:migrate --prefix backend",
    "publish:github": "bash scripts/publish-to-github.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
