# Monorepo — copy into frontend/.env and backend/.env (never commit real secrets)

# ─── frontend/.env ───
# NUXT_PUBLIC_SUPABASE_URL=
# NUXT_PUBLIC_SUPABASE_ANON_KEY=
# NUXT_PUBLIC_API_URL=https://your-api.up.railway.app

# ─── backend/.env ───
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
# OTP_SECRET=
# RESEND_API_KEY=
# EMAIL_FROM=
